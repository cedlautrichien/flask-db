<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<CC014C xmlns:ns2="urn:eds:datamodel:EDS:EDS_EXTENSIONS:1" xmlns:ns3="http://ncts.dgtaxud.ec"> 
	<Extensions>
		<SequenceNumeric>{{object.SequenceNumeric}}</SequenceNumeric>
		<Key>{{object.Key}}</Key>
		<Value>{{object.Value}}</Value>
